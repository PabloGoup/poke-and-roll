generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant: cada Local es un negocio cliente de Goup ───────────────────

enum RolUsuario {
  super_admin   // Goup: accede a todos los locales
  admin_local   // Dueño/gerente de un local específico
  operador      // Staff de un local (solo lectura ampliada)
}

model Local {
  id          String   @id @default(cuid())
  nombre      String
  slug        String   @unique
  activo      Boolean  @default(true)

  igPageId    String?  @unique @map("ig_page_id")
  fbPageId    String?  @unique @map("fb_page_id")
  waPhoneId   String?  @unique @map("wa_phone_id")

  igToken     String?  @map("ig_token")
  fbToken     String?  @map("fb_token")
  waToken     String?  @map("wa_token")

  usuarios       Usuario[]
  clientes       Cliente[]
  conversaciones Conversacion[]
  creadoEn       DateTime @default(now()) @map("creado_en")
  actualizadoEn  DateTime @updatedAt @map("actualizado_en")

  @@map("locales")
}

model Usuario {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String     @map("password_hash")
  nombre        String
  rol           RolUsuario @default(admin_local)
  activo        Boolean    @default(true)
  localId       String?    @map("local_id")
  local         Local?     @relation(fields: [localId], references: [id])
  creadoEn      DateTime   @default(now()) @map("creado_en")
  actualizadoEn DateTime   @updatedAt @map("actualizado_en")

  @@index([email])
  @@index([localId])
  @@map("usuarios")
}

// ──────────────────────────────────────────────────────────────────────────────

// ──────────────────────────────────────────────────────────────────────────────

enum Canal {
  whatsapp
  instagram
  facebook
}

enum DireccionMensaje {
  entrante
  saliente
}

enum EstadoConversacion {
  activa
  esperando_humano
  resuelta
  pausada
}

enum EstadoContenido {
  borrador
  aprobado
  programado
  publicado
  fallido
}

enum TipoContenido {
  historia
  post
  carrusel
  reel
}

enum EstadoAlerta {
  pendiente
  enviada
  fallida
}

enum PrioridadComercial {
  alta
  media
  baja
}

enum CanalComercial {
  todos
  whatsapp
  instagram
  facebook
}

enum TipoItemComercial {
  menu
  promocion
}

enum TipoCatalogoVisual {
  catalogo
  promocion
  roll_dia
  menu_dia
}

model Cliente {
  id              String         @id @default(cuid())
  localId         String?        @map("local_id")
  local           Local?         @relation(fields: [localId], references: [id])
  instagramId    String?        @unique @map("instagram_id")
  whatsappId     String?        @unique @map("whatsapp_id")
  facebookId     String?        @unique @map("facebook_id")
  nombre         String?
  telefono       String?
  etiquetas      String[]       @default([])
  conversaciones Conversacion[]
  reclamos       Reclamo[]
  creadoEn       DateTime       @default(now()) @map("creado_en")
  actualizadoEn  DateTime       @updatedAt @map("actualizado_en")

  @@index([localId])
  @@map("clientes")
}

model Conversacion {
  id                String             @id @default(cuid())
  localId           String?            @map("local_id")
  local             Local?             @relation(fields: [localId], references: [id])
  clienteId         String             @map("cliente_id")
  cliente           Cliente            @relation(fields: [clienteId], references: [id])
  canal             Canal
  instagramThreadId String?            @map("instagram_thread_id")
  whatsappThreadId  String?            @map("whatsapp_thread_id")
  estado            EstadoConversacion @default(activa)
  ultimaIntencion   String?            @map("ultima_intencion")
  requiereHumano    Boolean            @default(false) @map("requiere_humano")
  mensajes          Mensaje[]
  reclamos          Reclamo[]
  alertas           Alerta[]
  decisiones        DecisionAgente[]
  creadoEn          DateTime           @default(now()) @map("creado_en")
  actualizadoEn     DateTime           @updatedAt @map("actualizado_en")

  @@index([localId, canal, estado])
  @@map("conversaciones")
}

model Mensaje {
  id                 String           @id @default(cuid())
  conversacionId     String           @map("conversacion_id")
  conversacion       Conversacion     @relation(fields: [conversacionId], references: [id])
  canal              Canal
  direccion          DireccionMensaje
  texto              String
  payloadMeta        Json?            @map("payload_meta")
  idMensajeMeta      String?          @unique @map("id_mensaje_meta")
  idMensajeWhatsapp  String?          @unique @map("id_mensaje_whatsapp")
  creadoEn           DateTime         @default(now()) @map("creado_en")

  @@index([conversacionId, creadoEn])
  @@map("mensajes")
}

model MenuProducto {
  id             String   @id @default(cuid())
  nombre         String
  categoria      String
  descripcion    String?
  precio         Int
  disponible     Boolean  @default(true)
  imagenUrl      String?  @map("imagen_url")
  creadoEn       DateTime @default(now()) @map("creado_en")
  actualizadoEn  DateTime @updatedAt @map("actualizado_en")

  @@map("menu_productos")
}

model Promocion {
  id           String    @id @default(cuid())
  nombre       String
  descripcion  String
  precio       Int?
  fechaInicio  DateTime? @map("fecha_inicio")
  fechaFin     DateTime? @map("fecha_fin")
  activa       Boolean   @default(true)
  condiciones  String?

  @@map("promociones")
}

model ZonaDespacho {
  id                String   @id @default(cuid())
  nombre            String
  costo             Int
  tiempoEstimadoMin Int      @map("tiempo_estimado_min")
  tiempoEstimadoMax Int      @map("tiempo_estimado_max")
  activa            Boolean  @default(true)
  distanciaMinKm    Float?   @map("distancia_min_km")
  distanciaMaxKm    Float?   @map("distancia_max_km")

  @@map("zonas_despacho")
}

model ConfiguracionRestaurante {
  id        String  @id @default("restaurante")
  direccion String?
  latitud   Float?
  longitud  Float?

  @@map("configuracion_restaurante")
}

model DireccionGeocacheada {
  id            String   @id @default(cuid())
  hashTexto     String   @unique @map("hash_texto")
  textoOriginal String   @map("texto_original")
  latitud       Float
  longitud      Float
  creadoEn      DateTime @default(now()) @map("creado_en")

  @@map("direcciones_geocacheadas")
}

model HorarioAtencion {
  id           String  @id @default(cuid())
  diaSemana    Int     @map("dia_semana")
  horaApertura String  @map("hora_apertura")
  horaCierre   String  @map("hora_cierre")
  activo       Boolean @default(true)

  @@map("horarios_atencion")
}

model MedioPago {
  id            String  @id @default(cuid())
  nombre        String
  activo        Boolean @default(true)
  instrucciones String?

  @@map("medios_pago")
}

model ReglaComercialAgente {
  id             String              @id
  titulo         String
  descripcion   String
  activa         Boolean             @default(true)
  prioridad      PrioridadComercial  @default(media)
  canal          CanalComercial      @default(todos)
  creadoEn       DateTime            @default(now()) @map("creado_en")
  actualizadoEn  DateTime            @updatedAt @map("actualizado_en")

  @@map("reglas_comerciales_agente")
}

model ItemComercialDestacado {
  id             String            @id @default(cuid())
  tipo           TipoItemComercial
  nombre         String
  detalle        String
  precioTexto    String?           @map("precio_texto")
  activo         Boolean           @default(true)
  creadoEn       DateTime          @default(now()) @map("creado_en")
  actualizadoEn  DateTime          @updatedAt @map("actualizado_en")

  @@map("items_comerciales_destacados")
}

model CatalogoVisualAgente {
  id              String              @id @default(cuid())
  nombre          String
  url             String
  storagePath     String?             @map("storage_path")
  tipo            TipoCatalogoVisual  @default(catalogo)
  prioridadEnvio  Boolean             @default(false) @map("prioridad_envio")
  activo          Boolean             @default(true)
  creadoEn        DateTime            @default(now()) @map("creado_en")
  actualizadoEn   DateTime            @updatedAt @map("actualizado_en")

  @@index([prioridadEnvio, activo])
  @@map("catalogos_visuales_agente")
}

model Reclamo {
  id             String        @id @default(cuid())
  clienteId      String        @map("cliente_id")
  cliente        Cliente       @relation(fields: [clienteId], references: [id])
  conversacionId String        @map("conversacion_id")
  conversacion   Conversacion  @relation(fields: [conversacionId], references: [id])
  tipo           String
  descripcion    String
  estado         String        @default("abierto")
  prioridad      String        @default("media")
  asignadoA      String?       @map("asignado_a")
  alertas        Alerta[]
  creadoEn       DateTime      @default(now()) @map("creado_en")
  actualizadoEn  DateTime      @updatedAt @map("actualizado_en")

  @@map("reclamos")
}

model Contenido {
  id                String           @id @default(cuid())
  tipo              TipoContenido
  titulo            String
  copy              String
  cta               String?
  estado            EstadoContenido  @default(borrador)
  fechaProgramada   DateTime?        @map("fecha_programada")
  idPublicacionMeta String?          @map("id_publicacion_meta")
  piezas            ContenidoPieza[]
  creadoEn          DateTime         @default(now()) @map("creado_en")
  actualizadoEn     DateTime         @updatedAt @map("actualizado_en")

  @@map("contenidos")
}

model ContenidoPieza {
  id          String    @id @default(cuid())
  contenidoId String    @map("contenido_id")
  contenido   Contenido @relation(fields: [contenidoId], references: [id])
  orden       Int
  tipoMedia   String    @map("tipo_media")
  mediaUrl    String?   @map("media_url")
  texto       String?

  @@map("contenido_piezas")
}

model EventoMeta {
  id            String   @id @default(cuid())
  idEventoMeta  String   @unique @map("id_evento_meta")
  tipo          String
  payload       Json
  procesado     Boolean  @default(false)
  error         String?
  creadoEn      DateTime @default(now()) @map("creado_en")

  @@map("eventos_meta")
}

model Alerta {
  id             String        @id @default(cuid())
  conversacionId String?       @map("conversacion_id")
  conversacion   Conversacion? @relation(fields: [conversacionId], references: [id])
  reclamoId      String?       @map("reclamo_id")
  reclamo        Reclamo?      @relation(fields: [reclamoId], references: [id])
  canalDestino   String        @map("canal_destino")
  tipo           String
  mensaje        String
  estado         EstadoAlerta  @default(pendiente)
  payload        Json?
  creadoEn       DateTime      @default(now()) @map("creado_en")
  enviadoEn      DateTime?     @map("enviado_en")

  @@map("alertas")
}

model DecisionAgente {
  id                String       @id @default(cuid())
  conversacionId    String?      @map("conversacion_id")
  conversacion      Conversacion? @relation(fields: [conversacionId], references: [id])
  agente            String
  intencion         String
  entrada           String
  salida            String
  decisionSeguridad String       @map("decision_seguridad")
  creadoEn          DateTime     @default(now()) @map("creado_en")

  @@map("decisiones_agente")
}
